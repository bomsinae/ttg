{
  "timers": {
    "auto_refresh_interval_sec": 8,
    "peer_status_refresh_interval_sec": 15,
    "peer_status_typing_refresh_interval_sec": 3
  },
  "history": {
    "initial_message_limit": 80,
    "batch_size": 80
  },
  "keys": {
    "newline": "ctrl+n",
    "search_prev": "ctrl+p",
    "edit_older": "ctrl+e",
    "edit_newer": "ctrl+r",
    "cancel_edit": "ctrl+g",
    "delete_selected": "ctrl+d",
    "save_selected": "ctrl+w"
  },
  "logging": {
    "file": "logs/ttg.log",
    "level": "INFO",
    "max_bytes": 1000000,
    "backup_count": 3,
    "redact_secrets": true,
    "redact_phone_numbers": true
  }
}
